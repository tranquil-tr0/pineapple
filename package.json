{
  "name": "pizza",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun dev.mjs",
    "dev:server": "bun src/server/main.ts --watch",
    "dev:client": "vite dev",
    "build": "vite build && bun x tsc --project tsconfig.server.json",
    "start": "bun dist/server/main.js",
    "test": "bun run test:api && bun run test:e2e",
    "test:api": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "bun x tsc --noEmit && bun x tsc --noEmit --project tsconfig.server.json",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/client/styles/**/*.css\"",
    "check:unused:exports": "ts-prune -p tsconfig.json -i \"used in module\"",
    "check:unused:deps": "depcheck --skip-missing --ignore-dirs=dist,node_modules,deps,test-results --ignores=@types/express,@types/node,@types/ws,@playwright/test,vitest,vite,typescript,eslint,@eslint/js,typescript-eslint,eslint-plugin-lit,globals,stylelint,stylelint-config-standard,ts-prune,depcheck,lit",
    "check:e2e:guardrails": "bun scripts/check-e2e-guardrails.mjs",
    "check:e2e:guardrails:update-baseline": "bun scripts/check-e2e-guardrails.mjs --update-baseline",
    "check": "bun run typecheck && bun run lint && bun run lint:css && bun run check:e2e:guardrails && bun run check:unused:deps && bun run check:unused:exports && bun run test:api && bun run test:e2e && bun run build"
  },
  "dependencies": {
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^16.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.56.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-plugin-lit": "^2.2.1",
    "execa": "^9.6.1",
    "globals": "^17.3.0",
    "lit": "^3.3.1",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
